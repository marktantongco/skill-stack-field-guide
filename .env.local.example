# 21st.dev credentials — EXAMPLE FILE (safe to commit)
# ----------------------------------------------------------------------
# This file documents the canonical env var names. It contains NO real keys.
# Copy to .env.local and fill in your real values:
#   cp .env.local.example .env.local
#
# .env.local is gitignored (.env*) and never committed.
# For team secret sharing, use git-crypt (see SETUP_SECRETS.md).
#
# Canonical env var names (per @21st-dev/registry npm package, src/config.ts):
#   API_KEY_21ST   — primary, checked first  ← USE THIS
#   AN_API_KEY     — legacy alias
#
# Reference keys by NAME in all docs, code, and chat. Never by value.

# Primary 21st.dev API key (required for CLI + this wiki's /api/components proxy)
API_KEY_21ST=your_key_here

# Optional overrides (defaults shown). Uncomment to customize.
# API_URL_21ST=https://21st.dev/api/v1
# APP_URL_21ST=https://21st.dev

# Get your key at: https://21st.dev/studio/<your-handle>/api-keys
# Docs:            https://21st.dev/studio/<your-handle>/docs/cli
