# git-crypt — encrypt secrets at rest in git
#
# .env.local is encrypted via git-crypt. Safe to commit.
# Vercel uses a separate env var (API_KEY_21ST set in Vercel dashboard)
# because Vercel cannot run `git-crypt unlock` during build.

.env.local filter=git-crypt diff=git-crypt

# Encrypt any other secret files
*.secret filter=git-crypt diff=git-crypt
secrets/** filter=git-crypt diff=git-crypt

# Note: .env.local.example is NOT encrypted — it has placeholders only.
# Note: .env (tracked, contains only DATABASE_URL) is NOT encrypted — non-secret.
