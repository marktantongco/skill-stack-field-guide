# git-crypt — encrypt secrets at rest in git
#
# NOTE: .env.local is intentionally gitignored (see .gitignore) for Vercel
# compatibility. Vercel cannot run `git-crypt unlock` during build, so the
# API key is set as a Vercel environment variable instead.
#
# To re-enable committing .env.local encrypted (e.g. for a self-hosted deploy),
# uncomment the line below AND remove the .env.local exception in .gitignore:
#
# .env.local filter=git-crypt diff=git-crypt

# Encrypt any other secret files
*.secret filter=git-crypt diff=git-crypt
secrets/** filter=git-crypt diff=git-crypt

# Note: .env.local.example is NOT encrypted — it has placeholders only.
# Note: .env (tracked, contains only DATABASE_URL) is NOT encrypted — non-secret.
