// Prisma schema — full-stack portfolio backend
// KPI metrics + dashboard config (multi-user ready via userId field)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  configs   DashboardConfig[]
}

model KpiMetric {
  id        String   @id @default(cuid())
  kpiId     String   // "rev" | "users" | "orders" | "conv"
  label     String   // "Revenue"
  range     String   // "7D" | "30D" | "90D" | "YTD"
  value     Float
  delta     Float    // percentage change
  series    String   // JSON: [{day, v}]
  icon      String   // icon name
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([kpiId, range])
}

model DashboardConfig {
  id              String   @id @default(cuid())
  userId          String?  // null = demo/default user
  dashboardTitle  String   @default("The Dashboard")
  defaultRange    String   @default("30D") // "7D" | "30D" | "90D" | "YTD"
  refreshInterval Int      @default(12) // seconds, 0 = off
  showTable       Boolean  @default(true)
  showBarChart    Boolean  @default(true)
  visibleKpis     String   @default("rev,users,orders,conv") // CSV
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User?    @relation(fields: [userId], references: [id])

  @@unique([userId])
}
